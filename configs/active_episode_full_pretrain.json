{
  "execution": {
    "provider": "modal",
    "target_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 3600,
    "smoke_episodes": 2
  },
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "quality_metadata": "/artifacts/active/quality/full_pretrain_sample/active_quality_full.jsonl",
    "manifests": {
      "pretrain": "cache/manifests/pretrain_full_cached_urls.txt",
      "new": "cache/manifests/new_urls.txt"
    }
  },
  "episodes": {
    "n_episodes": 16,
    "seed": 20260428,
    "split": "pretrain",
    "support_source_groups_per_episode": 16,
    "heldout_source_groups_per_episode": 4,
    "support_clips_per_group": 6,
    "known_like_candidates_per_group": 1,
    "heldout_candidates_per_group": 1,
    "hidden_targets_per_group": 2,
    "near_duplicate_candidates": 8,
    "low_quality_candidates": 8,
    "low_quality_threshold": 0.45
  },
  "diagnostics": {
    "required_candidate_roles": [
      "known_like",
      "heldout_novel",
      "near_duplicate",
      "low_quality"
    ],
    "fail_on_violation": false
  },
  "artifacts": {
    "output_dir": "/artifacts/active/episodes/full_pretrain"
  }
}
