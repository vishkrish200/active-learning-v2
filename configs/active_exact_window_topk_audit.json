{
  "execution": {
    "provider": "modal",
    "data_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 1800
  },
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "manifests": {
      "pretrain": "cache/manifests/pretrain_full_cached_urls.txt",
      "new": "cache/manifests/new_urls.txt"
    }
  },
  "ranking": {
    "quality_threshold": 0.85,
    "max_stationary_fraction": 0.90,
    "max_abs_value": 60.0
  },
  "quality": {
    "sample_rate": 30.0,
    "max_samples_per_clip": 5400
  },
  "audit": {
    "top_n": 50,
    "top_n_smoke": 6,
    "disagreement_n": 30,
    "disagreement_n_smoke": 4,
    "rejected_n": 30,
    "rejected_n_smoke": 4,
    "top_ks": [10, 50, 100, 200],
    "max_plot_points": 1800,
    "generate_plots": true
  },
  "artifacts": {
    "exact_diagnostics_path": "/artifacts/active/final_blend_rank/exact_full_window_a05/active_exact_window_blend_diagnostics_full.csv",
    "consensus_diagnostics_path": "/artifacts/active/final_blend_rank/support_sampling_stability_a05_cpu/active_final_blend_consensus_diagnostics_full.csv",
    "output_dir": "/artifacts/active/final_blend_rank/exact_full_window_a05/topk_audit"
  }
}
