{
  "execution": {
    "provider": "modal",
    "target_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 14400,
    "smoke_max_episodes": 2
  },
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "quality_metadata": "/artifacts/active/quality/full_pretrain_sample/active_quality_full.jsonl",
    "manifests": {
      "pretrain": "cache/manifests/pretrain_full_cached_urls.txt",
      "new": "cache/manifests/new_urls.txt"
    }
  },
  "episodes": {
    "path": "/artifacts/active/episodes/scale_pretrain/active_episodes_full.jsonl"
  },
  "embeddings": {
    "cache_dir": "/artifacts/active/embedding_cache/ts2vec_candidate_medium"
  },
  "evaluation": {
    "representations": [
      "ts2vec",
      "window_mean_std_pool",
      "temporal_order",
      "raw_shape_stats",
      "window_shape_stats"
    ],
    "primary_representation": "ts2vec",
    "representation_options": {
      "ts2vec_checkpoint_path": "/artifacts/checkpoints/ts2vec_candidate_eval/ts2vec_best.pt",
      "ts2vec_device": "cuda"
    },
    "policies": [
      "old_novelty_only",
      "kcenter_greedy_quality_gated",
      "blend_old_novelty_ts2vec_window_mean_std_pool_a03",
      "blend_old_novelty_ts2vec_window_mean_std_pool_a05",
      "blend_old_novelty_ts2vec_window_mean_std_pool_a07",
      "blend_kcenter_ts2vec_window_mean_std_pool_a03",
      "blend_kcenter_ts2vec_window_mean_std_pool_a05",
      "blend_kcenter_ts2vec_window_mean_std_pool_a07",
      "window_shape_stats_q85_stat90_abs60_clustercap2"
    ],
    "k_values": [
      5,
      10,
      25,
      50,
      100
    ],
    "quality_threshold": 0.45,
    "random_seed": 20260429,
    "old_novelty_k": 10,
    "raw_shape_max_samples": 900,
    "cluster_similarity_threshold": 0.995,
    "max_episodes": 8
  },
  "artifacts": {
    "output_dir": "/artifacts/active/eval/ts2vec_window_blend_medium"
  }
}
