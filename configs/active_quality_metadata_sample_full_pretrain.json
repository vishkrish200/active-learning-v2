{
  "execution": {
    "provider": "modal",
    "target_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 7200,
    "smoke_max_clips_per_split": 2048
  },
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "manifests": {
      "pretrain": "cache/manifests/pretrain_full_cached_urls.txt",
      "new": "cache/manifests/new_urls.txt"
    }
  },
  "quality": {
    "sample_rate": 30.0,
    "max_samples_per_clip": 900,
    "low_quality_threshold": 0.45,
    "selection": {
      "splits": ["pretrain"],
      "sort_by": "sample_id",
      "max_clips_per_split": 5000
    }
  },
  "artifacts": {
    "output_dir": "/artifacts/active/quality/full_pretrain_sample"
  }
}
