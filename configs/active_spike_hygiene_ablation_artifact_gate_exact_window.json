{
  "execution": {
    "provider": "modal",
    "data_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 900,
    "smoke_max_rows": 128
  },
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "manifests": {
      "pretrain": "cache/manifests/pretrain_full_cached_urls.txt",
      "new": "cache/manifests/new_urls.txt"
    }
  },
  "ranking": {
    "query_split": "new"
  },
  "quality": {
    "sample_rate": 30.0,
    "max_samples_per_clip": 5400
  },
  "ablation": {
    "spike_rate_threshold": 0.025,
    "top_k_values": [10, 50, 100, 200],
    "generate_submissions": true
  },
  "artifacts": {
    "exact_diagnostics_path": "/artifacts/active/final_blend_rank/exact_full_window_a05/spike_hygiene_ablation/spike_hygiene_ablation_enriched_current_full.csv",
    "output_dir": "/artifacts/active/final_blend_rank/exact_full_window_a05/artifact_hygiene_ablation"
  }
}
