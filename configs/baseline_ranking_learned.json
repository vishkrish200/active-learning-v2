{
  "execution": {
    "provider": "modal",
    "data_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 3600
  },
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "pretrain_manifest": "cache/manifests/pretrain_urls.txt",
    "val_manifest": "cache/manifests/val_urls.txt",
    "feature_dim": 75
  },
  "artifacts": {
    "root": "/artifacts",
    "output_dir": "/artifacts/ranking/window_mean_std_learned_ranker"
  },
  "splits": {
    "support_split": "pretrain",
    "query_split": "val",
    "negative_split": "pretrain"
  },
  "ranking": {
    "representation": "window_mean_std_pool",
    "k_old": 10,
    "k_new_density": 10,
    "reranker_method": "cluster_aware",
    "cluster_similarity_threshold": 0.985,
    "cluster_bonus_weight": 0.25,
    "novelty_weight": 0.75,
    "mmr_lambda": 0.25,
    "k_values": [10, 50, 100, 200],
    "negative_sample_size": 500,
    "smoke_support_samples": 256,
    "smoke_query_samples": 64,
    "smoke_negative_samples": 64,
    "seed": 17
  },
  "grammar_features": {
    "enabled": true,
    "path_template": "/artifacts/tokens/window_mean_std_tokenizer/grammar_features_val_{mode}.csv",
    "use_in_score": true,
    "score_variant": "grammar_surprisal_mix",
    "score_weight": 0.15,
    "min_quality": 0.45,
    "min_new_density_score": 0.35,
    "ablation_report_path": "/artifacts/eval/grammar_ablation/grammar_leave_cluster_ablation_report_full.json"
  },
  "learned_ranker": {
    "enabled": true,
    "model_path": "/artifacts/ranking/window_mean_std_grammar_promoted/learned_ranker/learned_ranker_model_full.json",
    "score_transform": "sigmoid",
    "score_weight": 1.0
  },
  "quality": {
    "sample_rate": 30.0,
    "max_samples_per_clip": 5400
  },
  "corruption_eval": {
    "enabled": true,
    "sample_size": 128,
    "quality_score": 0.05,
    "modes": ["flatline", "spike", "saturation", "jitter"]
  }
}
