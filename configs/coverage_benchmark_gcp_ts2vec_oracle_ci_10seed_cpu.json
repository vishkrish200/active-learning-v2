{
  "purpose": "Next CPU-only blind-target coverage gate with oracle ceiling and episode-level CI reporting. No downstream training.",
  "execution": {
    "provider": "gcp_compute",
    "machine_type": "e2-standard-4",
    "zone": "us-central1-a",
    "max_runtime_minutes": 120,
    "no_gpu": true,
    "no_ts2vec_retraining": true,
    "no_downstream_training": true,
    "delete_vm_after_copy": true
  },
  "data": {
    "manifest": "artifacts/offline_active_benchmark/gcp_inputs/pretrain_urls_gcp_10000_g500_c20.txt",
    "max_rows_per_seed": 600,
    "max_groups": 200,
    "clips_per_group": 3,
    "sampling_mode": "random",
    "selection_seeds": [17, 23, 37, 41, 53, 67, 79, 83, 97, 101],
    "max_samples_per_clip": 900
  },
  "ts2vec": {
    "checkpoint_path": "/Users/vishnukrishnan/.config/superpowers/worktrees/active-learning-v2/codex/ts2vec-pipeline/artifacts/gcp_stage/checkpoints/ts2vec_candidate_eval/ts2vec_best.pt",
    "device": "cpu",
    "batch_size": 32
  },
  "benchmark": {
    "episode_strategy": "source_family_shift",
    "episode_representation": "window",
    "source_family_count": 4,
    "folds": 5,
    "candidate_groups_per_episode": 12,
    "target_groups_per_episode": 3,
    "max_support_groups": 96,
    "budgets": [1, 2, 4],
    "quality_threshold": 0.85,
    "max_stationary_fraction": 0.9,
    "max_abs_value": 60.0,
    "max_artifact_score": 0.05,
    "distance_metric": "euclidean",
    "representations": ["ts2vec", "window", "raw_shape_stats"],
    "eval_views": ["ts2vec", "window", "raw_shape_stats"],
    "primary_eval_views": ["window", "raw_shape_stats"],
    "eval_view_families": {
      "ts2vec": "ts2vec",
      "window": "window",
      "raw_shape_stats": "raw_shape"
    },
    "ts2vec_view": "ts2vec",
    "window_view": "window",
    "blend_alpha": 0.5,
    "policies": [
      "random_valid_v1",
      "quality_stratified_random_v1",
      "quality_only_v1",
      "window_support_novelty_v1",
      "window_kcenter_v1",
      "ts2vec_support_novelty_v1",
      "ts2vec_kcenter_v1",
      "submitted_full_replay_v1",
      "oracle_greedy_eval_view_v1"
    ]
  },
  "reporting": {
    "decision_report_script": "scripts/summarize_coverage_benchmark_reports.py",
    "baseline_policy": "quality_stratified_random_v1",
    "oracle_policy": "oracle_greedy_eval_view_v1",
    "bootstrap_replicates": 2000,
    "bootstrap_unit": "seed_episode"
  },
  "artifacts": {
    "local_output_dir": "artifacts/offline_active_benchmark/gcp_runs/20260508_blind_target_coverage_ts2vec_oracle_ci_10seed_cpu"
  },
  "acceptance": {
    "minimum_completed_seeds": 10,
    "minimum_episodes_per_seed": 5,
    "required_artifacts": [
      "selected_urls.txt",
      "blind_target_coverage_benchmark_report.json",
      "blind_target_coverage_benchmark_report.md",
      "coverage_proof_summary.json",
      "coverage_decision_report.json",
      "coverage_decision_report.md"
    ],
    "required_checks": [
      "source-group leakage is false",
      "frozen TS2Vec embeddings are used without retraining",
      "same-feature selector/eval rows are diagnostic, not primary",
      "selected_invalid_rate_max is zero",
      "selected_target_leak_count_total is zero",
      "oracle_greedy_eval_view_v1 is present and labeled non-deployable",
      "episode-level bootstrap CI is reported for top policy vs quality_stratified_random_v1",
      "oracle capture is reported for top deployable policy",
      "K=1, K=2, and K=4 are reported separately",
      "VM spawned for this run is deleted after artifact copy"
    ],
    "downstream_training_gate": [
      "top deployable policy lower 95% CI vs quality_stratified_random_v1 is greater than 0.04",
      "top deployable policy mean oracle capture is at least 0.40",
      "top deployable policy wins at least 70% of paired final episodes",
      "no primary eval view shows a meaningful negative delta"
    ]
  }
}
