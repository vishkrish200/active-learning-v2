{
  "purpose": "First actual downstream model-update task after stopping proxy-only loops. Selected raw IMU clips are added to support, a ridge autoregressive forecaster is retrained, and held-out target forecast MSE is measured. This is not a source-family pseudo-label proxy and does not retrain TS2Vec.",
  "execution": {
    "provider": "gcp_compute",
    "machine_type": "e2-standard-4",
    "zone": "us-central1-a",
    "max_runtime_minutes": 120,
    "no_gpu": true,
    "no_ts2vec_retraining": true,
    "no_large_downstream_training": true,
    "actual_downstream_model_update": true,
    "delete_vm_after_copy": true
  },
  "data": {
    "manifest": "artifacts/offline_active_benchmark/gcp_inputs/pretrain_urls_gcp_10000_g500_c20.txt",
    "max_rows_per_seed": 420,
    "max_groups": 140,
    "clips_per_group": 3,
    "sampling_mode": "random",
    "selection_seeds": [
      17
    ],
    "max_samples_per_clip": 900
  },
  "ts2vec": {
    "checkpoint_path": "/Users/vishnukrishnan/.config/superpowers/worktrees/active-learning-v2/codex/ts2vec-pipeline/artifacts/gcp_stage/checkpoints/ts2vec_candidate_eval/ts2vec_best.pt",
    "device": "cpu",
    "batch_size": 32
  },
  "benchmark": {
    "episode_strategy": "source_family_label_holdout",
    "episode_representation": "window",
    "source_family_count": 4,
    "folds": 4,
    "candidate_groups_per_episode": 12,
    "target_groups_per_episode": 6,
    "target_candidate_groups_per_episode": 4,
    "target_families_per_episode": 2,
    "max_support_groups": 96,
    "budgets": [
      1,
      2,
      4
    ],
    "quality_threshold": 0.85,
    "max_stationary_fraction": 0.9,
    "max_abs_value": 60.0,
    "max_artifact_score": 0.05,
    "distance_metric": "euclidean",
    "oracle_exact_combination_limit": 100000,
    "representations": [
      "ts2vec",
      "window",
      "raw_shape_stats"
    ],
    "eval_views": [
      "ts2vec",
      "window",
      "raw_shape_stats"
    ],
    "primary_eval_views": [
      "window",
      "raw_shape_stats"
    ],
    "eval_view_families": {
      "ts2vec": "ts2vec",
      "window": "window",
      "raw_shape_stats": "raw_shape"
    },
    "ts2vec_view": "ts2vec",
    "window_view": "window",
    "blend_alpha": 0.5,
    "policies": [
      "quality_stratified_random_v1",
      "quality_only_v1",
      "window_kcenter_v1",
      "submitted_full_replay_v1",
      "ts2vec_kcenter_v1"
    ]
  },
  "downstream_forecast": {
    "model": "raw_imu_autoregressive_ridge",
    "history_steps": 8,
    "horizon_steps": 1,
    "ridge_alpha": 0.01,
    "max_windows_per_clip": 128,
    "top_policy": "ts2vec_kcenter_v1",
    "baseline_policy": "quality_stratified_random_v1",
    "decision": "actual_downstream_model_update"
  },
  "reporting": {
    "decision_report_script": "scripts/summarize_coverage_benchmark_reports.py",
    "baseline_policy": "quality_stratified_random_v1",
    "oracle_policy": "oracle_exact_coverage_v1",
    "bootstrap_replicates": 500,
    "bootstrap_unit": "seed_episode"
  },
  "artifacts": {
    "local_output_dir": "artifacts/offline_active_benchmark/gcp_runs/20260509_downstream_forecast_task_quick"
  },
  "acceptance": {
    "minimum_completed_seeds": 1,
    "minimum_episodes_per_seed": 4,
    "required_artifacts": [
      "selected_urls.txt",
      "blind_target_coverage_benchmark_report.json",
      "blind_target_coverage_benchmark_report.md",
      "coverage_proof_summary.json",
      "downstream_forecast_task_report.json",
      "downstream_forecast_task_report.md",
      "coverage_decision_report.json",
      "coverage_decision_report.md"
    ],
    "required_checks": [
      "source-group leakage is false",
      "frozen TS2Vec embeddings are used without retraining",
      "budget 0 support-only forecast model is present",
      "selected candidate clips are added to forecast training support",
      "forecast model is retrained before held-out target MSE is measured",
      "ts2vec_kcenter_v1 is compared directly against quality_stratified_random_v1",
      "large_training remains hold",
      "ts2vec_retraining remains no",
      "VM spawned for this run is deleted after artifact copy"
    ],
    "promotion_rule": "If raw forecast target MSE improves against quality_stratified_random_v1, repeat this exact downstream task across three seeds before considering any nonlinear downstream model.",
    "non_claim": "This is an actual raw-IMU downstream model-update task, not a source-family pseudo-label proxy, but it is still a small linear forecaster rather than final challenge-label training proof."
  }
}
