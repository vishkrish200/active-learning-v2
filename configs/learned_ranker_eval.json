{
  "execution": {
    "provider": "modal",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 900
  },
  "artifacts": {
    "candidate_path": "/artifacts/ranking/window_mean_std_grammar_promoted/baseline_ranking_val_candidates_full.csv",
    "output_dir": "/artifacts/ranking/window_mean_std_grammar_promoted/learned_ranker"
  },
  "features": {
    "requested": [
      "quality_score",
      "old_knn_distance",
      "new_batch_density",
      "new_cluster_size",
      "is_singleton",
      "distance_to_new_cluster_medoid",
      "token_nll_mean",
      "token_nll_p95",
      "transition_nll_p95",
      "rare_phrase_fraction",
      "longest_unseen_phrase_len"
    ],
    "strict_feature_coverage": false
  },
  "eval": {
    "eval_fraction": 0.3,
    "seed": 29,
    "k_values": [10, 50, 100, 200],
    "baseline_score_columns": [
      "phase_a_final_score",
      "final_score",
      "old_knn_distance",
      "new_batch_density"
    ]
  }
}
