{
  "execution": {
    "provider": "modal",
    "gpu": "H100",
    "data_volume": "imu-novelty-subset-data",
    "artifacts_volume": "activelearning-imu-rebuild-cache",
    "timeout_seconds": 21600
  },
  "data": {
    "root": "/data",
    "format": "npz_features",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "pretrain_manifest": "cache/manifests/pretrain_urls.txt",
    "val_manifest": "cache/manifests/val_urls.txt",
    "train_split": "pretrain",
    "holdout_split": "val",
    "sample_rate": 30.0,
    "feature_dim": 75,
    "max_files_for_smoke": 16
  },
  "training": {
    "batch_size": 32,
    "learning_rate": 0.0003,
    "max_steps": 2000,
    "smoke_steps": 2,
    "validation_steps": 25,
    "seed": 7,
    "d_model": 128,
    "checkpoint_dir": "/artifacts/checkpoints",
    "validation_checkpoint_name": "validation_encoder_pretrain_only.pt",
    "full_checkpoint_name": "ssl_encoder_pretrain_only.pt"
  }
}
