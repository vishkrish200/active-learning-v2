    "target_groups_per_episode": 3,
    "max_support_groups": 128,
    "rounds": 2,
    "batch_size": 5,
    "oracle_candidate_cap": 24,
    "oracle_exact_combination_limit": 10000,
    "representations": ["ts2vec", "window", "raw_shape_stats"],
    "primary_representations": ["window", "raw_shape_stats"],
    "blend_left_representation": "ts2vec",
    "blend_right_representation": "window"
  },
  "artifacts": {
    "local_output_dir": "artifacts/offline_active_benchmark/gcp_runs/20260505_blend_alpha_artifact_sweep"
  },
  "acceptance": {
    "minimum_completed_cells": 15,
    "minimum_completed_seeds_per_cell": 3,
    "required_checks": [
      "each sweep cell includes the strong simple controls",
      "selection_details explain every selected clip",
      "report ranks blend cells by final cumulative gain against kcenter_quality_gated_window and old_novelty_window",
