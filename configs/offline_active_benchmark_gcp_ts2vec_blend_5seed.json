{
  "execution": {
    "provider": "gcp_compute",
    "machine_type": "e2-standard-4",
    "zone": "us-central1-a",
    "max_runtime_minutes": 120,
    "no_gpu": true,
    "no_training": true,
    "delete_vm_after_copy": true
  },
  "data": {
    "manifest": "data/modal_manifests/pretrain_urls.txt",
    "max_rows_per_seed": 10000,
    "max_groups": 500,
    "clips_per_group": 20,
    "sampling_mode": "random",
    "selection_seeds": [17, 23, 37, 41, 53],
    "max_samples_per_clip": 900
  },
  "ts2vec": {
    "checkpoint_path": "/Users/vishnukrishnan/.config/superpowers/worktrees/active-learning-v2/codex/ts2vec-pipeline/artifacts/gcp_stage/checkpoints/ts2vec_candidate_eval/ts2vec_best.pt",
    "device": "cpu",
    "batch_size": 32
  },
  "benchmark": {
    "episode_strategy": "hard",
    "episode_representation": "window",
    "folds": 3,
    "candidate_groups_per_episode": 2,
    "target_groups_per_episode": 3,
    "max_support_groups": 128,
    "rounds": 2,
    "batch_size": 5,
    "oracle_candidate_cap": 24,
    "oracle_exact_combination_limit": 10000,
    "representations": ["ts2vec", "window", "raw_shape_stats"],
    "primary_representations": ["window", "raw_shape_stats"],
    "blend_left_representation": "ts2vec",
    "blend_right_representation": "window",
    "blend_alpha": 0.5,
    "max_artifact_score": 0.05,
    "policies": [
      "random_valid",
      "quality_only",
      "old_novelty_window",
      "old_novelty_window_sourcecap2",
      "kcenter_quality_gated_window",
      "blend_kcenter_ts2vec_window",
      "artifact_gate_blend_kcenter_ts2vec_window",
      "submitted_full_replay",
      "submitted_minus_ts2vec",
      "submitted_minus_window",
      "submitted_no_kcenter",
      "window_novelty_same_gates_no_kcenter",
      "ts2vec_novelty_same_gates_no_kcenter",
      "oracle_greedy_eval_only"
    ]
  },
  "artifacts": {
    "local_output_dir": "artifacts/offline_active_benchmark/gcp_runs/20260505_10k_hard_ts2vec_blend_5seed"
  },
  "acceptance": {
    "minimum_completed_seeds": 5,
    "minimum_episodes_per_seed": 3,
    "required_checks": [
      "source-group leakage is false",
      "mean near-zero oracle round fraction remains below 0.25",
      "submitted-style blend policies are present in every policy summary",
      "paired deltas are reported for submitted-style ablations",
      "VM is deleted after artifact copy"
    ]
  }
