{
  "data": {
    "root": "/data",
    "feature_glob": "cache/features/*.npz",
    "raw_glob": "cache/raw/*.jsonl",
    "pretrain_manifest": "cache/manifests/pretrain_physical_source_urls.txt",
    "val_manifest": "cache/manifests/val_unused_for_submission_urls.txt"
  },
  "artifacts": {
    "root": "/artifacts",
    "output_dir": "/artifacts/eval/source_blocked/window_mean_std_physical_source_tiered_childcap2_5_subcluster40"
  },
  "ranking": {
    "representation": "window_mean_std_pool",
    "reranker_method": "tiered_cluster_cap",
    "cluster_similarity_threshold": 0.985,
    "cluster_bonus_weight": 0.0,
    "cluster_cap_top_k": 200,
    "cluster_max_per_cluster": 5,
    "cluster_cap_schedule": [
      {"top_k": 50, "max_per_cluster": 2},
      {"top_k": 200, "max_per_cluster": 5}
    ],
    "cluster_cap_key": "new_cluster_id",
    "cluster_cap_min_quality": 0.45,
    "novelty_weight": 0.75,
    "mmr_lambda": 0.0
  },
  "grammar_features": {
    "enabled": true,
    "path_template": "/artifacts/tokens/window_mean_std_tokenizer_worker_coverage_new/grammar_features_pretrain_full.csv",
    "extra_path_templates": [
      "/artifacts/tokens/window_mean_std_tokenizer_worker_coverage_new/grammar_features_pretrain_full.csv"
    ],
    "use_in_score": true,
    "score_variant": "quality_gated_grammar",
    "score_weight": 0.3,
    "min_quality": 0.45,
    "min_new_density_score": 0.0
  },
  "score_guards": {
    "stationary_singleton": {
      "enabled": true,
      "stationary_threshold": 0.90,
      "max_new_density_score": 0.35,
      "min_grammar_score": 0.85,
      "penalty_multiplier": 0.35
    }
  },
  "large_cluster_split": {
    "enabled": true,
    "method": "feature_kmeans",
    "max_cluster_size": 300,
    "target_subcluster_size": 40,
    "score_feature_weight": 0.0,
    "kmeans_iterations": 16,
    "score_columns": [
      "grammar_score_component",
      "grammar_score",
      "old_novelty_score",
      "new_density_score",
      "distance_to_new_cluster_medoid",
      "final_score"
    ]
  },
  "quality": {
    "sample_rate": 30.0,
    "max_samples_per_clip": 5400
  },
  "corruption_eval": {
    "enabled": true,
    "sample_size": 64,
    "raw_signal": true,
    "modes": ["flatline", "spike", "saturation", "jitter"]
  },
  "eval": {
    "max_rows": 20000,
    "smoke_max_rows": 512,
    "n_clusters": 64,
    "smoke_n_clusters": 12,
    "folds": 4,
    "smoke_folds": 2,
    "clusters_per_fold": 1,
    "source_groups_per_fold": 64,
    "max_positive_per_fold": 500,
    "max_negative_per_fold": 500,
    "min_source_covered_support_per_fold": 100,
    "k_old": 10,
    "k_new_density": 10,
    "candidate_cluster_similarity_threshold": 0.985,
    "low_quality_threshold": 0.45,
    "embedding_load_workers": 16,
    "kmeans_iterations": 10,
    "k_values": [10, 50, 100, 200]
  },
  "seed": 17
}
